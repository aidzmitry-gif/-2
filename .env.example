# Подключение к PostgreSQL.
# Для стресс-теста важен достаточный размер пула (>= числа параллельных запросов),
# поэтому добавлены connection_limit и pool_timeout.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booking?schema=public&connection_limit=50&pool_timeout=30"

# Порт HTTP-сервера
PORT=3000

# Пароль администратора (вход в админку). Обязательно поменяйте в проде.
ADMIN_PASSWORD="admin-secret"

# --- Демонстрация защиты на стенде (необязательно) ---
# Отключить блокировку строки мастера (SELECT ... FOR UPDATE), чтобы показать,
# что последним рубежом остаётся EXCLUDE-constraint. Значение "off" выключает второй уровень.
BOOKING_SERIALIZE=on

# --- Бонус: Telegram-уведомления (необязательно) ---
# Если оба значения заданы — мастеру будут уходить уведомления о записи/отмене.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
