{
  "name": "booking-2.0",
  "version": "1.0.0",
  "description": "Система записи: несколько мастеров, конкурентный доступ, таймзоны, лист ожидания, realtime (SSE).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "seed": "tsx src/seed.ts",
    "stress": "tsx scripts/stress.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "6.19.3",
    "@prisma/client": "6.19.3",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "luxon": "3.7.2",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/luxon": "3.7.1",
    "@types/node": "22.19.20",
    "@types/pg": "8.20.0",
    "prisma": "6.19.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
